{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@db/*": ["src/db/*"],
      "@engine/*": ["src/engine/*"],
      "@store/*": ["src/store/*"],
      "@components/*": ["src/components/*"]
    }
  }
}
